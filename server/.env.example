# Server Environment Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/interview-ai
JWT_SECRET=your_jwt_secret_key_here

# Token Expiry Settings
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# File Upload Limit
MAX_FILE_SIZE_MB=5

# Demo Admin Configuration (Optional for development)
DEMO_ADMIN_EMAIL=admin@interviewai.local
DEMO_ADMIN_PASSWORD=Admin@123

# AI Configuration (Gemini & Groq)
# Set AI_PROVIDER to 'gemini' or 'groq'
AI_PROVIDER=gemini
AI_MODEL=llama-3.3-70b-versatile

# API Keys (Only stored on backend, never exposed to frontend)

GROQ_API_KEY=